<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/3.1.1"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/3.1.1 http://maven.apache.org/xsd/assembly-3.1.1.xsd">
	<id>sr.we</id>
	<formats>
		<format>zip</format>
	</formats>
	<includeBaseDirectory>false</includeBaseDirectory>
	<fileSets>
		<fileSet>
			<directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
			<includes>
				<include>${project.build.directory}/SeaQns.jar</include>
				<include>${project.build.directory}/SeaQns.exe</include>
				<include>${project.build.directory}/SeaQns.xml</include>
				<!--<include>application.properties</include>-->
			</includes>
		</fileSet>
	</fileSets>
</assembly>