	<parameter name="TRANSACTION_RECEIVED" class="java.math.BigDecimal"/>
	<parameter name="TRANSACTION_CHANGE" class="java.math.BigDecimal"/>
	<parameter name="POS_DUE" class="java.math.BigDecimal"/>
	<parameter name="TRANSACTION_STATUS" class="java.lang.String"/>
	<parameter name="TRANSACTION_ID" class="java.lang.Long"/>
	<parameter name="POS_ID" class="java.lang.Long"/>
	<parameter name="POS_PAID" class="java.math.BigDecimal"/>
	<parameter name="CUR_FROM" class="java.lang.String"/>
	<parameter name="CUR_TO" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    ph.id                 AS ticket_id,
    c.id                 AS customer_id,
    curfrom.id           AS currency_from_id,
    curto.id             AS currency_to_id,
    ph.exchange_rate      AS xf,
    ph.converted_amount   AS xf_amount,
    ph.header_seq     AS ticket_number,
    c.first_name         AS customer_first,
    c.name               AS customer_last,
    ph.discount,
    ph.exchange_rate,
    curfrom.code         AS currency_from_code,
    curto.code           AS currency_to_code,
    phd.name             AS item,
    phd.count            AS item_count,
    phd.price            AS item_price,
    phd.result           AS item_total
FROM
    pos_header         ph
    LEFT OUTER JOIN pos_header_detail   phd ON phd.pos_header_id_ = ph.id
    LEFT OUTER JOIN customer            c ON ph.customer_id_ = c.id
    LEFT JOIN currency            curfrom ON ph.currency_from_id_ = curfrom.id
    LEFT JOIN currency            curto ON ph.currency_to_id_ = curto.id
WHERE
    ph.id =  $P{POS_ID}]]>
	</queryString>
