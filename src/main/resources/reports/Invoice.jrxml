		<parameter name="INVOICE_DUE" class="java.math.BigDecimal"/>
		<queryString>
			<![CDATA[select pt.payment_date as PAYMENT_DATE,
pt. converted_amount as CONVERTED_AMOUNT,
pm.description as PAYMENT_METHOD,
c.CODE as CURRENCY_FROM_CODE
from payment_transaction pt left outer join payment_method pm on
pt.payment_method_id_ = pm.id
left outer join currency c on c.id = pt.currency_from_id_
where pt.reference = 'INVOICE'
and pt.reference_id_ =    $P{INVOICE_ID}]]>
		</queryString>
		<field name="PAYMENT_DATE" class="java.sql.Date">
			<property name="com.jaspersoft.studio.field.name" value="PAYMENT_DATE"/>
			<property name="com.jaspersoft.studio.field.label" value="PAYMENT_DATE"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="payment_transaction"/>
		</field>
		<field name="CONVERTED_AMOUNT" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="CONVERTED_AMOUNT"/>
			<property name="com.jaspersoft.studio.field.label" value="CONVERTED_AMOUNT"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="payment_transaction"/>
		</field>
		<field name="PAYMENT_METHOD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="DESCRIPTION"/>
			<property name="com.jaspersoft.studio.field.label" value="PAYMENT_METHOD"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="payment_method"/>
		</field>
