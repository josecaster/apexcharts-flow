	<parameter name="INVOICE_ID_" class="java.lang.Long"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    i.id as invoice_id,
    c.id as customer_id,
    b.id as business_id,
    ph.id as header_id,
    curfrom.id as currency_from_id,
    curto.id as currency_to_id,
    i.exchange_rate as xf,
    i.amount as invoice_amount,
    i.converted_amount as xf_amount,
    i.invoice_number as invoice_number,
    i.invoice_date as invoice_date,
    i.payment_due as invoice_due,
    i.thank_message as invoice_thk ,
    i.header_message as invoice_head,
    i.footer_message as invoice_foot,
    i.invoice_title as invoice_tit,
    c.first_name as customer_first,
    c.name as customer_last,
    cc.email as customer_mail,
    cc.mobile as customer_mob,
    b.name as business_name,
    curfrom.code as currency_from_code,
    curto.code as currency_to_code,
    phd.name as item,
    phd.count as item_count,
    phd.price as item_price,
    phd.result as item_total
FROM
    invoice      i
    LEFT JOIN pos_header   ph ON i.pos_header_id_ = ph.id
    LEFT OUTER JOIN pos_header_detail phd on phd.pos_header_id_ = ph.id
    LEFT OUTER JOIN customer     c ON i.customer_id_ = c.id
    LEFT OUTER JOIN customer_address ca on ca.customer_id_ = c.id
    LEFT OUTER JOIN customer_billing cb on cb.customer_address_id_ = ca.id
    LEFT OUTER JOIN customer_contact cc on cc.customer_id_ = c.id
    LEFT OUTER JOIN customer_shipping cs on cs.customer_address_id_ = ca.id
    LEFT JOIN business b on i.business_id_ = b.id
    LEFT JOIN currency curfrom on i.currency_from_id_ = curfrom.id
    LEFT JOIN currency curto on i.currency_to_id_ = curto.id
WHERE
    i.id =  $P{INVOICE_ID_}]]>
	</queryString>
